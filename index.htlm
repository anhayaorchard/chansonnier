<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chansonnier Basque - Euskal Kantutegia</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        /* Style pour garder les sauts de ligne dans les paroles */
        .lyrics-box p { margin-bottom: 1rem; line-height: 1.75; font-family: Georgia, Cambria, "Times New Roman", Times, serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 h-screen flex flex-col overflow-hidden">

    <header class="bg-emerald-800 text-white shadow-md p-4 flex items-center justify-between z-10">
        <h1 class="text-xl md:text-2xl font-bold tracking-wide flex items-center gap-2">
            <i class="fa-solid fa-music text-emerald-300"></i> Chansonnier Basque
        </h1>
        <span class="text-xs bg-emerald-950/50 px-3 py-1.5 rounded-full border border-emerald-600/30">
            <i class="fa-solid fa-sync fa-spin mr-1 text-emerald-400"></i> Google Sheet connecté
        </span>
    </header>

    <div class="flex-1 flex flex-col md:flex-row overflow-hidden">
        
        <aside class="w-full md:w-80 lg:w-96 bg-white border-r border-slate-200 flex flex-col h-2/5 md:h-full shadow-sm">
            <div class="p-4 border-b border-slate-200 bg-slate-50/50 space-y-3">
                <div class="relative">
                    <input type="text" id="searchInput" placeholder="Rechercher un chant, auteur, paroles..." 
                           class="w-full pl-10 pr-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 text-sm">
                    <i class="fa-solid fa-magnifying-glass absolute left-3 top-3 text-slate-400"></i>
                </div>
                <div>
                    <select id="dialectFilter" class="w-full bg-white border border-slate-300 rounded-lg p-2 text-xs md:text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                        <option value="">Tous les dialectes</option>
                    </select>
                </div>
            </div>
            
            <div id="songList" class="flex-1 overflow-y-auto divide-y divide-slate-100">
                <div class="p-8 text-center text-slate-500">
                    <i class="fa-solid fa-spinner fa-spin text-2xl text-emerald-600 mb-2 block"></i>
                    Chargement du chansonnier...
                </div>
            </div>
        </aside>

        <main id="detailPanel" class="flex-1 bg-slate-50 overflow-y-auto p-4 md:p-8 flex flex-col justify-center items-center text-slate-400">
            <i class="fa-solid fa-music text-6xl mb-4 text-slate-200"></i>
            <p class="text-lg font-medium text-slate-500">Sélectionnez une chanson dans la liste pour afficher ses paroles</p>
        </main>
    </div>

    <script>
        // Configuration : Remplace par ton ID de document si nécessaire
        const SPREADSHEET_ID = '1q_4V-Mv_vxYpR6Dyt58jGec6u8nelQaXmkn3yu8xTak';
        const SPREADSHEET_URL = `https://docs.google.com/spreadsheets/d/${SPREADSHEET_ID}/gviz/tq?tqx=out:json`;

        let songs = [];

        // 1. Chargement des données depuis Google Sheets
        async function loadData() {
            try {
                const response = await fetch(SPREADSHEET_URL);
                const text = await response.text();
                
                // Extraction du JSON propre depuis l'enveloppe de Google API
                const jsonString = text.slice(text.indexOf('{'), text.lastIndexOf('}') + 1);
                const json = JSON.parse(jsonString);

                const cols = json.table.cols.map(c => c.label || '');
                songs = json.table.rows.map((r, index) => {
                    const song = {};
                    r.c.forEach((cell, idx) => {
                        const colName = cols[idx] || `col_${idx}`;
                        song[colName] = cell ? cell.v : '';
                    });
                    if (!song['ID']) song['ID'] = index + 1;
                    return song;
                }).filter(song => song['Izenbürüa']); // On ne garde que les lignes avec un titre

                populateDialectFilter();
                renderSongList();
            } catch (error) {
                console.error("Erreur lors du chargement :", error);
                document.getElementById('songList').innerHTML = `
                    <div class="p-4 text-red-600 text-sm text-center font-medium">
                        <i class="fa-solid fa-circle-exclamation text-xl mb-2 block"></i>
                        Impossible de charger les chansons.<br>Vérifiez le partage du Google Sheet.
                    </div>`;
            }
        }

        // Remplir le filtre de dialectes dynamiquement
        function populateDialectFilter() {
            const dialects = [...new Set(songs.map(s => s['Eüskalkia']).filter(Boolean))];
            const select = document.getElementById('dialectFilter');
            dialects.forEach(d => {
                const opt = document.createElement('option');
                opt.value = d;
                opt.textContent = d;
                select.appendChild(opt);
            });
        }

        // Afficher la liste des chants
        function renderSongList(filteredSongs = songs) {
            const listEl = document.getElementById('songList');
            if (filteredSongs.length === 0) {
                listEl.innerHTML = `<div class="p-8 text-center text-slate-400 text-sm">Aucun chant ne correspond</div>`;
                return;
            }

            listEl.innerHTML = filteredSongs.map(song => `
                <button onclick="selectSong(${song['ID']})" class="w-full text-left p-4 hover:bg-emerald-50/50 focus:outline-none focus:bg-emerald-50 transition border-l-4 border-transparent hover:border-emerald-600 block">
                    <div class="font-bold text-slate-800 text-sm md:text-base">${song['Izenbürüa']}</div>
                    <div class="flex items-center justify-between mt-1 gap-2">
                        <span class="text-xs text-slate-500 truncate">${song['Koblakaria'] || 'Auteur inconnu'}</span>
                        ${song['Eüskalkia'] ? `<span class="text-[10px] bg-emerald-100 text-emerald-800 px-2 py-0.5 rounded-full font-semibold shrink-0">${song['Eüskalkia']}</span>` : ''}
                    </div>
                </button>
            `).join('');
        }

        // Filtrer les chants (Recherche textuelle + Dialecte)
        function filterSongs() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const dialect = document.getElementById('dialectFilter').value;

            const filtered = songs.filter(song => {
                const matchesSearch = 
                    (song['Izenbürüa'] && song['Izenbürüa'].toString().toLowerCase().includes(search)) ||
                    (song['Koblakaria'] && song['Koblakaria'].toString().toLowerCase().includes(search)) ||
                    (song['Nonkoa'] && song['Nonkoa'].toString().toLowerCase().includes(search)) ||
                    (song['Oraiko idazkera'] && song['Oraiko idazkera'].toString().toLowerCase().includes(search)) ||
                    (song['Frantsesera ützülpena'] && song['Frantsesera ützülpena'].toString().toLowerCase().includes(search));
                
                const matchesDialect = !dialect || song['Eüskalkia'] === dialect;
                return matchesSearch && matchesDialect;
            });

            renderSongList(filtered);
        }

        // Détecter et générer un lecteur d'intégration YouTube
        function getYoutubeEmbedUrl(url) {
            if (!url) return null;
            let videoId = '';
            if (url.includes('youtube.com/watch')) {
                try {
                    const urlParams = new URLSearchParams(new URL(url).search);
                    videoId = urlParams.get('v');
                } catch(e) {}
            } else if (url.includes('youtu.be/')) {
                videoId = url.split('youtu.be/')[1]?.split('?')[0];
            }
            return videoId ? `https://www.youtube.com/embed/${videoId}` : null;
        }

        // Formater le texte des paroles (paragraphes et sauts de ligne)
        function formatLyrics(text) {
            if (!text) return '<p class="text-slate-400 italic">Non renseigné</p>';
            return `<div class="lyrics-box text-slate-700 font-serif text-sm md:text-base leading-relaxed"><p>` + 
                text.toString()
                    .replace(/\n\n/g, '</p><p>')
                    .replace(/\n/g, '<br>') + 
                `</p></div>`;
        }

        // Sélectionner et afficher un chant en détail
        function selectSong(id) {
            const song = songs.find(s => s['ID'] == id);
            if (!song) return;

            const detailPanel = document.getElementById('detailPanel');
            detailPanel.className = "flex-1 bg-white overflow-y-auto p-4 md:p-8 flex flex-col";
            
            const hasPhonetic = !!song['Ahozkatzeko idazkera'];
            const hasTranslation = !!song['Frantsesera ützülpena'];

            // Ajustement dynamique du nombre de colonnes selon les traductions dispos
            let colsCount = 1;
            if (hasPhonetic) colsCount++;
            if (hasTranslation) colsCount++;

            let gridClass = "grid grid-cols-1 gap-6 mt-6";
            if (colsCount === 2) gridClass = "grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6";
            if (colsCount === 3) gridClass = "grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6";

            // Gestion de l'audio
            let audioHtml = '';
            if (song['Audio ütürria']) {
                const ytEmbed = getYoutubeEmbedUrl(song['Audio ütürria']);
                if (ytEmbed) {
                    audioHtml = `
                        <div class="mt-8 border-t border-slate-100 pt-6">
                            <h4 class="text-sm font-bold text-slate-700 mb-3"><i class="fa-brands fa-youtube text-red-600 mr-2"></i>Écouter l'interprétation</h4>
                            <div class="aspect-video w-full max-w-xl rounded-xl overflow-hidden shadow-md">
                                <iframe class="w-full h-full" src="${ytEmbed}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                            </div>
                        </div>`;
                } else {
                    audioHtml = `
                        <div class="mt-8 border-t border-slate-100 pt-6">
                            <h4 class="text-sm font-bold text-slate-700 mb-2"><i class="fa-solid fa-headphones text-emerald-600 mr-2"></i>Source audio</h4>
                            <p class="text-sm text-slate-600 font-medium">${song['Audio ütürria']}</p>
                        </div>`;
                }
            }

            detailPanel.innerHTML = `
                <div class="border-b border-slate-200 pb-6">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <h2 class="text-2xl md:text-4xl font-extrabold text-slate-900">${song['Izenbürüa']}</h2>
                        ${song['Eüskalkia'] ? `<span class="bg-emerald-100 text-emerald-800 text-xs px-3 py-1 rounded-full font-bold shadow-sm">${song['Eüskalkia']}</span>` : ''}
                    </div>
                    
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6 text-xs md:text-sm text-slate-600">
                        <div>
                            <span class="block text-slate-400 text-[10px] font-bold uppercase tracking-wider">Auteur</span>
                            <span class="font-semibold text-slate-800">${song['Koblakaria'] || '—'}</span>
                        </div>
                        <div>
                            <span class="block text-slate-400 text-[10px] font-bold uppercase tracking-wider">Compositeur / Arr.</span>
                            <span class="font-semibold text-slate-800">${song['Hontzalea'] || '—'}</span>
                        </div>
                        <div>
                            <span class="block text-slate-400 text-[10px] font-bold uppercase tracking-wider">Œuvre / Recueil</span>
                            <span class="font-semibold text-slate-800">${song['Nonkoa'] || '—'}</span>
                        </div>
                        <div>
                            <span class="block text-slate-400 text-[10px] font-bold uppercase tracking-wider">Année</span>
                            <span class="font-semibold text-slate-800">${song['Urtea'] || '—'}</span>
                        </div>
                    </div>
                </div>

                <div class="${gridClass} flex-1">
                    <div class="bg-slate-50 p-6 rounded-2xl border border-slate-200/60 shadow-sm">
                        <h3 class="text-xs font-bold text-emerald-800 uppercase tracking-widest mb-4 border-b border-emerald-200 pb-2 flex justify-between items-center">
                            <span>Oraiko idazkera</span>
                            <span class="text-[9px] bg-emerald-200/50 text-emerald-900 px-2 py-0.5 rounded">Basque</span>
                        </h3>
                        ${formatLyrics(song['Oraiko idazkera'])}
                    </div>

                    ${hasPhonetic ? `
                    <div class="bg-amber-50/40 p-6 rounded-2xl border border-amber-200/50 shadow-sm">
                        <h3 class="text-xs font-bold text-amber-800 uppercase tracking-widest mb-4 border-b border-amber-200 pb-2 flex justify-between items-center">
                            <span>Ahozkatzeko idazkera</span>
                            <span class="text-[9px] bg-amber-100 text-amber-900 px-2 py-0.5 rounded">Phonétique</span>
                        </h3>
                        ${formatLyrics(song['Ahozkatzeko idazkera'])}
                    </div>` : ''}

                    ${hasTranslation ? `
                    <div class="bg-slate-50/50 p-6 rounded-2xl border border-slate-200/60 shadow-sm">
                        <h3 class="text-xs font-bold text-slate-600 uppercase tracking-widest mb-4 border-b border-slate-200 pb-2 flex justify-between items-center">
                            <span>Traduction</span>
                            <span class="text-[9px] bg-slate-200 text-slate-700 px-2 py-0.5 rounded">Français</span>
                        </h3>
                        ${formatLyrics(song['Frantsesera ützülpena'])}
                    </div>` : ''}
                </div>

                ${song['Oharrak'] ? `
                <div class="mt-6 bg-blue-50/40 border border-blue-200/50 p-4 rounded-xl text-slate-700">
                    <h4 class="text-xs font-bold text-blue-900 uppercase tracking-widest mb-1"><i class="fa-solid fa-circle-info mr-1"></i>Notes</h4>
                    <p class="text-sm leading-relaxed">${song['Oharrak']}</p>
                </div>` : ''}

                ${audioHtml}
            `;
            
            // Sur mobile, scroller doucement vers le panneau de détail après sélection
            if (window.innerWidth < 768) {
                detailPanel.scrollIntoView({ behavior: 'smooth' });
            }
        }

        // Ecouteurs d'événements pour la recherche en temps réel
        document.getElementById('searchInput').addEventListener('input', filterSongs);
        document.getElementById('dialectFilter').addEventListener('change', filterSongs);

        // Lancement au chargement de la page
        loadData();
    </script>
</body>
</html>
